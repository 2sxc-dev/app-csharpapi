@inherits Custom.Hybrid.RazorTyped
@using ToSic.Razor.Blade
@using System.Linq
@using AppCode
@using AppCode.Models

@{
  var dllInfo = MyModel.Get<ApiAssemblyInfo>("DllInfo");
  var currentNs = MyModel.String("currentNs");
}
<table x-class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Σ</th>
      <th>📊</th>
      <th>⚙️</th>
      <th>✏️</th>
    </tr>
  </thead>
  <tbody>
    @foreach (var ns in dllInfo.Namespaces.Relevant) {
      var title = ns.Namespace;
      var trunc = title.Length < 10
        ? title
        : title
            .Replace("ToSic.SexyContent.", "...SexyContent.")
            .Replace("ToSic.", ".");

      var cnf = ns.Rule?.SharedRule == false ? ns.Rule : null;
      var tlb = cnf == null
        ? Kit.Toolbar.Empty().New("RuleNamespace", tweak: t => t.Prefill(new { Title = title }))
        : Kit.Toolbar.Edit(cnf);

      var nsRule = ns.Rule;

    var configInfo = nsRule?.IgnoreAll == true
      ? new InfoWithIcon("🦘*", "Ignore everything")
      : nsRule?.IgnoreTypeMembers == true
        ? new InfoWithIcon("🦘🎛️", "Ignore type members")
        : new InfoWithIcon("", "");


      var relevantSubRules = ns.Types.Relevant
        .Where(t => t.Rule != null)
        .ToList();

      <tr class='@(ns.Namespace == currentNs ? "selected" : "")' @tlb>
        <td>
          <a href='@Link.To(parameters: MyPage.Parameters.Filter("Dll,Namespace").Toggle("Namespace", title))' title="@title">
            @Html.Raw(Text.Ellipsis(trunc, 20))
          </a>
        </td>
        <td>
          @ns.Overall.Icon
        </td>
        <td title='@(ns.Types?.SummaryInfo)'>
          @(ns.Types?.Summary)
        </td>

        @* Configuration *@
        <td style='@(nsRule?.SharedRule == true ? "opacity: 0.4" : "")'>
          <span title='@configInfo.Message'>
            @configInfo.Icon
          </span>
          @if (relevantSubRules.Count > 0) {
            <span title="has sub-rules for types">
              (@relevantSubRules.Count)
            </span>
          }
        </td>

      </tr>
    }
  </tbody>
</table>
