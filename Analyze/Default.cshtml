@inherits Custom.Hybrid.RazorTyped
@using System.IO
@using AppCode
@using AppCode.Analyzers
@using AppCode.Models

<h1 @Kit.Toolbar.Default()>Manage Public C# APIs</h1>

<p>
  See <code>readme.md</code> for more information.
</p>

@{
  // Determine configuration based on url parameters
  var pars = MyPage.Parameters;
  var publicOnly = pars.Bool("PublicOnly", fallback: true);
  var dllSelected = pars.IsNotEmpty("Dll");
  var dllName = pars.Get("Dll", fallback: Constants.ToSicSxc);
  var nsSelected = pars.IsNotEmpty("Namespace");
  var currentNs = pars.Get("Namespace");

  var typeSelected = pars.IsNotEmpty("Type");
  var currentType = pars.Get("Type");

  // Member Selection (Property, Method)
  var memberSelected = pars.IsNotEmpty("Member");
  var selectedMemberName = pars.Get("Member");
}

<a class='btn @(publicOnly ? "btn-primary" : "btn-secondary")' href='@Link.To(parameters: pars.Toggle("PublicOnly", false))'>
  @(publicOnly ? "✅" : "❌")
  Public Only
</a>

<a type="button" class='btn @(dllName != "" ? "btn-primary" : "btn-secondary")' href='@Link.To(parameters: pars.Toggle("Dll", dllName))'>
  @if (dllName == "")
  {
    <text>➖ All Dlls</text>
  }
  else
  {
    <text>✅ @dllName</text>
  }
</a>

<a class='btn btn-success' href='@Link.To(parameters: pars.Toggle("Analyze-All", true))' target="_blank">
  Analyze All
</a>

@{
  // Get the bin folder of the current razor

  var dllPath = System.IO.Path.Combine(App.Folder.PhysicalPath, Constants.PathToDlls);
  var dlls = new DirectoryInfo(dllPath)
    .GetFiles("*.dll")
    .Select(x => x.Name)
    .ToList();
  var currentDll = dllName + ".dll";
}


<div>
  BasePath: @Constants.PathToDlls <br>
  DllPath: @dllPath <br>
  Dlls: @dlls.Count <br>
  Current DLL: @currentDll <br>
</div>

@{
  var assemblyInfoSvc = GetService<AssemblyInfoManager>();
  var dllInfo = assemblyInfoSvc
    .GetOrCreate(name: dllName, path: System.IO.Path.Combine(dllPath, currentDll), alwaysRecreate: true);
  var nsInfo = dllInfo.Namespaces.All
    .FirstOrDefault(x => x.Namespace == currentNs);
  var classInfo = nsInfo?.Types.All
    .FirstOrDefault(x => x.Name == currentType);

  var infoItem = memberSelected
    ? classInfo?.Members.Relevant
      .FirstOrDefault(m => m.Name == selectedMemberName) as ICommonInfo
    : classInfo as ICommonInfo;

}

<h2>Stats @dllInfo.Name</h2>
<ul>
  <li>Types: @dllInfo.Types.Summary</li>
  <li>Namespaces: @dllInfo.Namespaces.Summary</li>
</ul>

<div class="viewport-breakout" style="background: white; padding-left: 10px">
  <table class="table">
    <tr>
      <th>Dll</th>
      <th>Namespace in @dllInfo.Name (@dllInfo.Namespaces.Summary)</th>
      <th>
        Classes in @(nsInfo?.Namespace)
        (@(nsInfo?.Types.Summary))
        @(nsInfo?.Overall.Icon)
      </th>
      <th>
        Members in @(classInfo?.Name)
        (@(classInfo?.Members.Summary))
        @(classInfo?.Overall.Icon)
      </th>
      <th>
        @if (memberSelected) {
          <text>Details of @selectedMemberName</text>
        } else {
          <text>Member Details</text>
        }
      </th>
    </tr>
    <tr>
      <td>
        @Html.Partial("./Dlls.cshtml", new { currentDll = dllName })
      </td>
      <td>
        @* todo: if DllSelected *@
        @if (dllSelected) {
          @Html.Partial("./Namespaces.cshtml", new { dllInfo, currentNs, currentType })
        } else {
          <text>No Dll Selected</text>
        }
      </td>
      <td>
        @if (nsSelected) {
          @Html.Partial("./Classes.cshtml", new { dllInfo, currentNs, currentType, nsInfo })
        } else {
          <text>No Namespace Selected</text>
        }
      </td>
      <td>
        @if (typeSelected) {
          @Html.Partial("./ClassMembers.cshtml", new { dllInfo, currentNs, currentType, nsInfo, classInfo, selectedMemberName })
        } else {
          <text>No class Selected</text>
        }
      </td>
      <td>
        @if (infoItem != null) {
          @Html.Partial("./ClassMembers Details.cshtml", new { parentName = currentType, info = infoItem, })
        } else {
          <text>No Member Selected</text>
        }
      </td>
    </tr>
  </table>
</div>

<style>
  a {
    text-decoration: underline;
  }
  tr.selected {
    background-color: #eee;
  }

  .viewport-breakout {
    /* Step 1: Make the width 100vw minus the 80px sidebar */
    width: calc(100vw - 80px);
    
    position: relative;
    
    /* Step 2: Push it 80px to the right to clear the CMS bar, 
      then pull it back by half of the NEW viewport width */
    /* left: calc(50% + 80px); */
    left: calc(50% + 0px);
    right: 50%;
    
    margin-left: calc(-50vw + 40px); /* 40px is half of 80px */
    margin-right: -50vw;
  }
</style>

