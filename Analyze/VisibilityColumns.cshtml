@inherits Custom.Hybrid.RazorTyped
@using AppCode
@using AppCode.Models

@{
  var visibility = MyModel.Get<IVisibility>("Visibility");
  var total = MyModel.Get<Status>("Total", required: false);
}

<td title="@(total?.Details)">
    @(total?.Icon ?? "-")
</td>

<td title="@visibility.Summary.Details">
  @visibility.Summary.Icon
</td>

<td title="@(visibility.IsPublic ? "Public" : "Not public")">
  @Show.BoolMoji(visibility.IsPublic, Constants.VisPublic, Constants.VisInvisible)
</td>

<td title='@visibility.Docs.Details'>
  @visibility.Docs.Icon
</td>

<td title='@visibility.EditorStatus.Details'>
  @visibility.EditorStatus.Icon
</td>
